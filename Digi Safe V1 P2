<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DigiSafe — Online Digital Repository | sprintcart</title>
<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;600;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet"/>
<style>
  :root{--teal:#0D9E8A;--teal-dark:#097A6A;--teal-light:#E6F7F5;--blue:#1A6FDB;--blue-light:#E8F1FC;--green:#3DBD6A;--green-dark:#2A9A51;--green-light:#E8F8EE;--dark:#0A1628;--mid:#2C4A6E;--muted:#5B7899;--light:#F2F7F6;--white:#FFFFFF;--border:#D5E8E4;--shadow:0 4px 24px rgba(13,158,138,0.10);--shadow-lg:0 20px 60px rgba(13,158,138,0.14);}
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{font-family:'Instrument Sans',sans-serif;color:var(--dark);background:var(--white);overflow-x:hidden;}
  h1,h2,h3,h4,h5{font-family:'Cabinet Grotesk',sans-serif;line-height:1.1;}
  a{text-decoration:none;color:inherit;}
  nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,0.96);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);padding:0 5%;height:68px;display:flex;align-items:center;justify-content:space-between;transition:box-shadow 0.3s;}
  nav.scrolled{box-shadow:0 2px 24px rgba(0,0,0,0.07);}
  .logo-text{font-family:'Cabinet Grotesk',sans-serif;font-size:1.45rem;font-weight:900;letter-spacing:-0.5px;}
  .logo-text .blue{color:var(--blue);}.logo-text .green{color:var(--green);}
  .logo-badge{font-size:0.6rem;color:var(--muted);letter-spacing:0.5px;}
  .nav-right{display:flex;align-items:center;gap:12px;}
  .nav-back{font-size:0.84rem;color:var(--muted);display:flex;align-items:center;gap:5px;padding:8px 14px;border-radius:8px;transition:background 0.2s;font-weight:500;}
  .nav-back:hover{background:var(--teal-light);color:var(--teal-dark);}
  .nav-cta{background:var(--teal);color:white;padding:10px 20px;border-radius:8px;font-weight:700;font-size:0.88rem;transition:background 0.2s,transform 0.15s;font-family:'Cabinet Grotesk',sans-serif;}
  .nav-cta:hover{background:var(--teal-dark);transform:translateY(-1px);}
  /* HERO */
  .hero{min-height:100vh;padding:110px 5% 80px;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;position:relative;overflow:hidden;background:linear-gradient(150deg,#EAF7F4 0%,#F8FFFE 50%,#EFF8F0 100%);}
  .hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(13,158,138,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(13,158,138,0.04) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;}
  .hero-glow{position:absolute;top:-100px;right:-60px;width:600px;height:600px;background:radial-gradient(ellipse,rgba(13,158,138,0.10) 0%,transparent 65%);border-radius:50%;pointer-events:none;}
  .hero-left{position:relative;z-index:1;animation:fadeUp 0.8s ease both;}
  .hero-right{position:relative;z-index:1;animation:fadeRight 0.9s 0.15s ease both;}
  @keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeRight{from{opacity:0;transform:translateX(28px)}to{opacity:1;transform:translateX(0)}}
  .breadcrumb{display:flex;align-items:center;gap:5px;font-size:0.77rem;color:var(--muted);margin-bottom:20px;}
  .breadcrumb .cur{color:var(--teal);font-weight:600;}
  .hero-badge{display:inline-flex;align-items:center;gap:8px;background:white;border:1px solid var(--border);border-radius:100px;padding:6px 14px 6px 8px;font-size:0.77rem;font-weight:600;color:var(--teal-dark);margin-bottom:22px;box-shadow:0 2px 8px rgba(13,158,138,0.08);}
  .bdot{width:6px;height:6px;background:var(--teal);border-radius:50%;animation:pulse 2s infinite;}
  @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(1.4)}}
  .hero h1{font-size:clamp(2.8rem,5vw,4.2rem);font-weight:900;letter-spacing:-2.5px;color:var(--dark);line-height:1.02;margin-bottom:10px;}
  .hero h1 .acc{color:var(--teal);}
  .hero-tagline{font-family:'Cabinet Grotesk',sans-serif;font-size:0.88rem;font-weight:700;color:var(--teal);margin-bottom:18px;letter-spacing:0.3px;text-transform:uppercase;}
  .hero-desc{font-size:0.98rem;color:var(--muted);line-height:1.78;max-width:500px;margin-bottom:32px;}
  .hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px;}
  .btn-primary{background:var(--teal);color:white;padding:13px 26px;border-radius:10px;font-weight:700;font-size:0.92rem;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 16px rgba(13,158,138,0.28);transition:background 0.2s,transform 0.15s,box-shadow 0.2s;font-family:'Cabinet Grotesk',sans-serif;}
  .btn-primary:hover{background:var(--teal-dark);transform:translateY(-2px);box-shadow:0 8px 24px rgba(13,158,138,0.35);}
  .btn-outline{background:white;color:var(--teal);padding:13px 26px;border-radius:10px;font-weight:700;font-size:0.92rem;border:1.5px solid var(--teal);display:inline-flex;align-items:center;gap:8px;transition:background 0.2s,transform 0.15s;font-family:'Cabinet Grotesk',sans-serif;}
  .btn-outline:hover{background:var(--teal-light);transform:translateY(-2px);}
  .trust-row{display:flex;gap:20px;flex-wrap:wrap;padding-top:18px;border-top:1px solid var(--border);}
  .ti{display:flex;align-items:center;gap:6px;font-size:0.79rem;color:var(--muted);font-weight:500;}
  /* hero card */
  .hv-wrap{position:relative;max-width:460px;margin:0 auto;}
  .hv-card{background:white;border-radius:20px;border:1px solid var(--border);box-shadow:var(--shadow-lg);padding:24px;}
  .hvc-title{font-family:'Cabinet Grotesk',sans-serif;font-size:0.68rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:14px;}
  .hvc-pillars{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
  .hvc-pillar{background:var(--light);border-radius:10px;padding:12px;border:1px solid var(--border);}
  .hvp-icon{font-size:1.2rem;margin-bottom:5px;}
  .hvp-name{font-family:'Cabinet Grotesk',sans-serif;font-size:0.75rem;font-weight:700;color:var(--dark);line-height:1.3;}
  .hvc-divider{height:1px;background:var(--border);margin:10px 0;}
  .hvc-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);font-size:0.76rem;}
  .hvc-row:last-child{border-bottom:none;}
  .hvc-row .rk{color:var(--muted);}.hvc-row .rv{font-weight:600;color:var(--dark);}.hvc-row .rv.g{color:var(--teal);}
  .hvc-pill{display:inline-flex;align-items:center;background:var(--teal-light);color:var(--teal-dark);font-size:0.63rem;font-weight:700;padding:2px 7px;border-radius:100px;}
  .hfc{position:absolute;background:white;border-radius:12px;border:1px solid var(--border);box-shadow:0 8px 32px rgba(0,0,0,0.09);padding:11px 14px;animation:float 4s ease-in-out infinite;z-index:3;}
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
  .hfc-tl{top:-16px;right:-14px;animation-delay:0s;min-width:140px;}
  .hfc-br{bottom:-14px;left:-16px;animation-delay:1.6s;min-width:158px;}
  .hfc-lbl{font-size:0.6rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:3px;}
  .hfc-val{font-family:'Cabinet Grotesk',sans-serif;font-size:1.15rem;font-weight:900;color:var(--teal);}
  .hfc-sub{font-size:0.63rem;color:var(--muted);margin-top:1px;}
  .hfc-row{display:flex;align-items:center;gap:7px;}
  .hfc-ico{width:24px;height:24px;border-radius:6px;background:var(--teal-light);display:flex;align-items:center;justify-content:center;font-size:0.8rem;flex-shrink:0;}
  .hfc-t{font-size:0.74rem;font-weight:600;color:var(--dark);}.hfc-s{font-size:0.61rem;color:var(--muted);}
  /* SHARED */
  section{padding:88px 5%;}
  .mw{max-width:1200px;margin:0 auto;}
  .eyebrow{display:inline-block;font-size:0.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--teal);margin-bottom:12px;}
  .sec-title{font-size:clamp(1.9rem,3vw,2.6rem);font-weight:900;color:var(--dark);letter-spacing:-1px;margin-bottom:14px;}
  .sec-sub{font-size:0.96rem;color:var(--muted);line-height:1.75;max-width:560px;margin-bottom:48px;}
  .center{text-align:center;}.center .sec-sub{margin:0 auto 48px;}
  /* PROBLEM */
  .prob-sec{background:var(--dark);padding:80px 5%;position:relative;overflow:hidden;}
  .prob-sec::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(13,158,138,0.10),transparent 60%);pointer-events:none;}
  .prob-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;position:relative;}
  .pl .ptag{display:inline-flex;align-items:center;gap:6px;background:rgba(13,158,138,0.14);border:1px solid rgba(13,158,138,0.28);border-radius:100px;padding:5px 12px;font-size:0.72rem;color:#4DD9C8;font-weight:600;margin-bottom:18px;}
  .pl h2{font-family:'Cabinet Grotesk',sans-serif;font-size:clamp(1.9rem,3vw,2.5rem);font-weight:900;color:white;letter-spacing:-1px;margin-bottom:14px;line-height:1.08;}
  .pl h2 span{color:#4DD9C8;}
  .pl p{font-size:0.91rem;color:rgba(255,255,255,0.52);line-height:1.78;margin-bottom:24px;}
  .end-callout{background:rgba(13,158,138,0.08);border:1px solid rgba(13,158,138,0.2);border-radius:14px;padding:20px 22px;}
  .ec-tag{font-size:0.68rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#4DD9C8;margin-bottom:7px;}
  .end-callout p{font-size:0.88rem;color:rgba(255,255,255,0.65);line-height:1.6;margin:0;font-style:italic;}
  .prob-list{display:flex;flex-direction:column;gap:9px;}
  .prob-item{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:10px;padding:13px 16px;display:flex;align-items:flex-start;gap:11px;transition:border-color 0.2s;}
  .prob-item:hover{border-color:rgba(13,158,138,0.25);}
  .pi-icon{width:30px;height:30px;border-radius:7px;background:rgba(255,90,90,0.12);border:1px solid rgba(255,90,90,0.16);display:flex;align-items:center;justify-content:center;font-size:0.85rem;flex-shrink:0;margin-top:1px;}
  .pi-text{font-size:0.82rem;color:rgba(255,255,255,0.62);line-height:1.5;}
  .pi-text strong{color:rgba(255,255,255,0.9);font-weight:600;}
  /* PLATFORM TABS */
  .platform-sec{background:var(--light);}
  .platform-inner{max-width:1160px;margin:0 auto;}
  .ptabs{display:flex;gap:0;background:white;border:1.5px solid var(--border);border-radius:14px;overflow:hidden;max-width:680px;margin:0 auto 48px;}
  .ptab{flex:1;padding:12px 10px;font-family:'Cabinet Grotesk',sans-serif;font-size:0.82rem;font-weight:700;cursor:pointer;color:var(--muted);transition:all 0.22s;text-align:center;border-right:1.5px solid var(--border);line-height:1.3;}
  .ptab:last-child{border-right:none;}
  .ptab.active{background:var(--teal);color:white;}
  .ptab:not(.active):hover{background:var(--teal-light);color:var(--teal-dark);}
  .ppanel{display:none;grid-template-columns:1fr 1fr;gap:56px;align-items:start;}
  .ppanel.active{display:grid;}
  .pp-left .pp-tag{font-size:0.68rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--teal);margin-bottom:10px;}
  .pp-left h2{font-family:'Cabinet Grotesk',sans-serif;font-size:clamp(1.6rem,2.5vw,2.1rem);font-weight:900;color:var(--dark);letter-spacing:-0.8px;margin-bottom:12px;}
  .pp-left p{font-size:0.93rem;color:var(--muted);line-height:1.75;margin-bottom:22px;}
  .pp-list{display:flex;flex-direction:column;gap:9px;margin-bottom:28px;}
  .pp-item{display:flex;align-items:flex-start;gap:9px;font-size:0.87rem;color:var(--mid);}
  .pp-item::before{content:'✓';color:var(--teal);font-weight:700;flex-shrink:0;margin-top:1px;}
  .pp-right{background:white;border-radius:18px;border:1px solid var(--border);padding:24px;box-shadow:var(--shadow);}
  .ppr-label{font-family:'Cabinet Grotesk',sans-serif;font-size:0.67rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
  .ppr-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);font-size:0.79rem;}
  .ppr-row:last-child{border-bottom:none;}
  .ppr-row .rk{color:var(--muted);}.ppr-row .rv{font-weight:600;color:var(--dark);}.ppr-row .rv.g{color:var(--teal);}
  .ppr-pill{display:inline-flex;align-items:center;background:var(--teal-light);color:var(--teal-dark);font-size:0.63rem;font-weight:700;padding:2px 8px;border-radius:100px;}
  .ppr-icon-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:4px;}
  .ppr-ig{background:var(--light);border-radius:9px;padding:11px;}
  .pig-icon{font-size:1.1rem;margin-bottom:5px;}
  .pig-name{font-family:'Cabinet Grotesk',sans-serif;font-size:0.73rem;font-weight:700;color:var(--dark);margin-bottom:2px;}
  .pig-desc{font-size:0.67rem;color:var(--muted);line-height:1.4;}
  .ppr-mini{background:linear-gradient(135deg,#07503F,#0D9E8A);border-radius:10px;padding:14px 16px;color:white;display:flex;align-items:center;gap:11px;margin-top:12px;}
  .ppr-mini-icon{width:36px;height:36px;border-radius:9px;background:rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
  .ppr-mini-t{font-family:'Cabinet Grotesk',sans-serif;font-size:0.83rem;font-weight:700;}
  .ppr-mini-s{font-size:0.69rem;color:rgba(255,255,255,0.55);}
  /* MODULES */
  .modules-sec{background:white;}
  .modules-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;max-width:1100px;margin:0 auto;}
  .mod-card{border-radius:18px;border:1px solid var(--border);padding:30px;transition:transform 0.22s,box-shadow 0.22s,border-color 0.22s;position:relative;overflow:hidden;background:white;}
  .mod-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:18px 18px 0 0;}
  .mod-card.mc-social::before{background:linear-gradient(90deg,#2A9A51,#3DBD6A);}
  .mod-card.mc-connect::before{background:linear-gradient(90deg,#0F4FA0,#1A6FDB);}
  .mod-card.mc-bhasha::before{background:linear-gradient(90deg,#6B21A8,#A855F7);}
  .mod-card.mc-stream::before{background:linear-gradient(90deg,#92400E,#F59E0B);}
  .mod-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg);border-color:var(--teal);}
  .mod-tag{display:inline-block;font-family:'Cabinet Grotesk',sans-serif;font-size:0.66rem;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:3px 9px;border-radius:100px;margin-bottom:14px;}
  .mt-social{background:#E8F8EE;color:#1A6F44;}.mt-connect{background:var(--blue-light);color:#0F4FA0;}.mt-bhasha{background:#F3E8FF;color:#6B21A8;}.mt-stream{background:#FEF3C7;color:#92400E;}
  .mod-icon{width:50px;height:50px;border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:14px;}
  .mi-social{background:#E8F8EE;}.mi-connect{background:var(--blue-light);}.mi-bhasha{background:#F3E8FF;}.mi-stream{background:#FEF3C7;}
  .mod-card h3{font-family:'Cabinet Grotesk',sans-serif;font-size:1.12rem;font-weight:800;color:var(--dark);margin-bottom:6px;}
  .mod-card .mod-desc{font-size:0.87rem;color:var(--muted);line-height:1.65;margin-bottom:16px;}
  .mod-benefits{display:flex;flex-direction:column;gap:6px;}
  .mb{font-size:0.81rem;color:var(--mid);display:flex;align-items:flex-start;gap:7px;line-height:1.45;}
  .mb::before{content:'→';color:var(--teal);font-weight:700;flex-shrink:0;font-size:0.76rem;margin-top:1px;}
  .db-stat-strip{display:flex;gap:10px;margin-top:14px;flex-wrap:wrap;}
  .dbss{background:var(--light);border-radius:9px;padding:9px 14px;border:1px solid var(--border);}
  .dbss-val{font-family:'Cabinet Grotesk',sans-serif;font-size:1.2rem;font-weight:900;color:var(--teal);}
  .dbss-lbl{font-size:0.67rem;color:var(--muted);margin-top:1px;}
  /* CEHA */
  .ceha-sec{background:var(--light);}
  .ceha-inner{max-width:1000px;margin:0 auto;}
  .ceha-header{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;margin-bottom:0;}
  .ch-left .ceha-badge{display:inline-flex;align-items:center;gap:6px;background:white;border:1.5px solid var(--teal);border-radius:100px;padding:6px 14px;font-size:0.73rem;font-weight:700;color:var(--teal-dark);margin-bottom:14px;}
  .ch-left h2{font-family:'Cabinet Grotesk',sans-serif;font-size:clamp(1.7rem,2.5vw,2.2rem);font-weight:900;color:var(--dark);letter-spacing:-0.8px;margin-bottom:10px;}
  .ch-left p{font-size:0.91rem;color:var(--muted);line-height:1.72;}
  .ch-right{background:white;border-radius:14px;border:1px solid var(--border);padding:20px 24px;}
  .chr-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
  .chr-row:last-child{border-bottom:none;}
  .chr-icon{width:36px;height:36px;border-radius:9px;background:var(--teal-light);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
  .chr-name{font-family:'Cabinet Grotesk',sans-serif;font-size:0.88rem;font-weight:700;color:var(--dark);margin-bottom:2px;}
  .chr-desc{font-size:0.75rem;color:var(--muted);line-height:1.4;}
  /* DIGIAI */
  .digiai-sec{background:var(--dark);padding:80px 5%;position:relative;overflow:hidden;}
  .digiai-sec::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(13,158,138,0.07),transparent 55%);pointer-events:none;}
  .dai-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;position:relative;}
  .dai-left .dai-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(255,200,0,0.10);border:1px solid rgba(255,200,0,0.2);border-radius:100px;padding:5px 12px;font-size:0.72rem;color:#FFD060;font-weight:600;margin-bottom:18px;}
  .dai-soon{display:inline-block;font-size:0.6rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;background:rgba(255,200,0,0.15);color:#FFD060;padding:2px 7px;border-radius:100px;margin-left:4px;}
  .dai-left h2{font-family:'Cabinet Grotesk',sans-serif;font-size:clamp(1.8rem,2.8vw,2.4rem);font-weight:900;color:white;letter-spacing:-0.8px;margin-bottom:10px;}
  .dai-left h2 .acc{color:#FFD060;}
  .dai-left .dai-sub{font-size:0.91rem;color:rgba(255,255,255,0.5);line-height:1.75;margin-bottom:26px;}
  .dai-cols{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  .dai-col h4{font-family:'Cabinet Grotesk',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:#4DD9C8;margin-bottom:10px;}
  .dai-list{display:flex;flex-direction:column;gap:7px;}
  .dai-li{font-size:0.81rem;color:rgba(255,255,255,0.52);display:flex;align-items:flex-start;gap:7px;line-height:1.45;}
  .dai-li::before{content:'·';color:#4DD9C8;font-weight:700;flex-shrink:0;font-size:1rem;line-height:1.2;}
  .dai-right{display:flex;flex-direction:column;gap:12px;}
  .dai-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:18px 20px;display:flex;align-items:flex-start;gap:12px;transition:border-color 0.2s,background 0.2s;}
