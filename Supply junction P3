<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Supply Junction — Enterprise Procurement Management | sprintcart</title>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Epilogue:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --navy:#0B1E3D;--navy-mid:#132A52;--navy-light:#1C3868;
  --amber:#F59E0B;--amber-dark:#D97706;--amber-light:#FEF3C7;
  --green:#16A34A;--green-light:#DCFCE7;
  --sc-blue:#1A6FDB;--sc-green:#3DBD6A;
  --dark:#0B1E3D;--mid:#2D4A7A;--muted:#6B8CB8;
  --light:#F0F4FA;--white:#FFFFFF;--border:#CBD8F0;
  --shadow:0 4px 24px rgba(11,30,61,.10);
  --shadow-lg:0 20px 60px rgba(11,30,61,.18);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Epilogue',sans-serif;color:var(--dark);background:var(--white);overflow-x:hidden}
h1,h2,h3,h4{font-family:'Bricolage Grotesque',sans-serif;line-height:1.1}
a{text-decoration:none;color:inherit}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,.96);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);padding:0 5%;height:68px;display:flex;align-items:center;justify-content:space-between;transition:box-shadow .3s}
nav.scrolled{box-shadow:0 2px 24px rgba(0,0,0,.07)}
.lt{font-family:'Bricolage Grotesque',sans-serif;font-size:1.45rem;font-weight:800;letter-spacing:-.5px}
.lt .b{color:var(--sc-blue)}.lt .g{color:var(--sc-green)}
.lb{font-size:.6rem;color:var(--muted);letter-spacing:.5px}
.nr{display:flex;align-items:center;gap:12px}
.nbk{font-size:.84rem;color:var(--muted);display:flex;align-items:center;gap:5px;padding:8px 14px;border-radius:8px;transition:background .2s;font-weight:500}
.nbk:hover{background:var(--amber-light);color:var(--amber-dark)}
.nct{background:var(--amber);color:var(--navy);padding:10px 20px;border-radius:8px;font-weight:700;font-size:.88rem;transition:background .2s,transform .15s;font-family:'Bricolage Grotesque',sans-serif}
.nct:hover{background:var(--amber-dark);transform:translateY(-1px)}

/* HERO */
.hero{min-height:100vh;padding:110px 5% 80px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;position:relative;overflow:hidden;background:var(--navy)}
.hero::before{content:'';position:absolute;top:-80px;right:-60px;width:700px;height:700px;background:radial-gradient(ellipse,rgba(245,158,11,.08) 0%,transparent 65%);border-radius:50%;pointer-events:none}
.hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(245,158,11,.3),transparent)}
.hgrid{position:absolute;inset:0;background-image:linear-gradient(rgba(245,158,11,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(245,158,11,.04) 1px,transparent 1px);background-size:52px 52px;pointer-events:none}
.hl{position:relative;z-index:1;animation:fu .8s ease both}
.hr{position:relative;z-index:1;animation:fir .9s .2s ease both}
@keyframes fu{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes fir{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
.bc{display:flex;align-items:center;gap:5px;font-size:.77rem;color:rgba(255,255,255,.4);margin-bottom:20px}
.bc .cur{color:var(--amber);font-weight:600}
.hbg{display:inline-flex;align-items:center;gap:8px;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.25);border-radius:100px;padding:6px 14px 6px 8px;font-size:.77rem;font-weight:600;color:var(--amber);margin-bottom:22px}
.bdot{width:6px;height:6px;background:var(--amber);border-radius:50%;animation:bp 2s infinite}
@keyframes bp{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
.hero h1{font-size:clamp(2.6rem,4.5vw,4rem);font-weight:800;letter-spacing:-2px;color:white;line-height:1.04;margin-bottom:10px}
.hero h1 .ac{color:var(--amber)}
.htag{font-size:.95rem;font-weight:500;color:rgba(255,255,255,.5);margin-bottom:20px}
.hero-sub{font-size:1rem;color:rgba(255,255,255,.7);line-height:1.75;max-width:520px;margin-bottom:32px}
.ha{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px}
.bpa{background:var(--amber);color:var(--navy);padding:13px 26px;border-radius:10px;font-weight:700;font-size:.92rem;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 16px rgba(245,158,11,.3);transition:background .2s,transform .15s;font-family:'Bricolage Grotesque',sans-serif}
.bpa:hover{background:var(--amber-dark);transform:translateY(-2px)}
.boa{background:transparent;color:white;padding:13px 26px;border-radius:10px;font-weight:600;font-size:.92rem;border:1.5px solid rgba(255,255,255,.25);display:inline-flex;align-items:center;gap:8px;transition:background .2s,transform .15s;font-family:'Bricolage Grotesque',sans-serif}
.boa:hover{background:rgba(255,255,255,.06);transform:translateY(-2px)}
.tr{display:flex;gap:20px;flex-wrap:wrap;padding-top:18px;border-top:1px solid rgba(255,255,255,.1)}
.ti{display:flex;align-items:center;gap:6px;font-size:.79rem;color:rgba(255,255,255,.45);font-weight:500}

/* HERO VISUAL */
.hvc{position:relative;width:100%;max-width:460px;margin:0 auto}
.hvm{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:24px;backdrop-filter:blur(10px)}
.hvmt{font-size:.67rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:16px}
.ps-list{display:flex;flex-direction:column;gap:0}
.ps-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.05)}
.ps-item:last-child{border-bottom:none}
.ps-num{width:32px;height:32px;border-radius:50%;background:rgba(245,158,11,.15);border:1px solid rgba(245,158,11,.3);display:flex;align-items:center;justify-content:center;font-family:'Bricolage Grotesque',sans-serif;font-size:.75rem;font-weight:700;color:var(--amber);flex-shrink:0}
.ps-label{font-size:.83rem;font-weight:600;color:white}
.ps-sub{font-size:.68rem;color:rgba(255,255,255,.38)}
.hvd{height:1px;background:rgba(255,255,255,.08);margin:14px 0}
.hvsr{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.hvs{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:12px;text-align:center}
.hvs-v{font-family:'Bricolage Grotesque',sans-serif;font-size:1.1rem;font-weight:800;color:var(--amber);line-height:1}
.hvs-l{font-size:.63rem;color:rgba(255,255,255,.38);margin-top:4px;line-height:1.3}
.hfc{position:absolute;background:var(--navy-mid);border:1px solid rgba(245,158,11,.2);border-radius:12px;padding:12px 15px;animation:fl 4s ease-in-out infinite;z-index:3}
@keyframes fl{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.hfc-tl{top:-16px;left:-18px;min-width:138px;animation-delay:.5s}
.hfc-br{bottom:-14px;right:-14px;min-width:148px;animation-delay:1.8s}
.hfcl{font-size:.62rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:4px}
.hfcv{font-family:'Bricolage Grotesque',sans-serif;font-size:1.2rem;font-weight:900;color:var(--amber)}
.hfcs{font-size:.64rem;color:rgba(255,255,255,.35);margin-top:2px}

/* SECTIONS */
section{padding:88px 5%}
.mw{max-width:1200px;margin:0 auto}
.ew{display:inline-block;font-size:.71rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--amber);margin-bottom:12px}
.st{font-size:clamp(1.9rem,3vw,2.6rem);font-weight:800;color:var(--dark);letter-spacing:-.8px;margin-bottom:14px}
.ss{font-size:.95rem;color:var(--muted);line-height:1.75;max-width:560px;margin-bottom:48px}
.cnt{text-align:center}.cnt .ss{margin:0 auto 48px}

/* PROBLEM */
.prob-sec{background:var(--light);padding:80px 5%}
.prob-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.pltag{display:inline-flex;align-items:center;gap:6px;background:var(--amber-light);border:1px solid rgba(245,158,11,.3);border-radius:100px;padding:5px 12px;font-size:.73rem;color:var(--amber-dark);font-weight:600;margin-bottom:18px}
.prob-inner h2{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(1.8rem,3vw,2.4rem);font-weight:800;color:var(--dark);letter-spacing:-.8px;margin-bottom:14px}
.prob-inner h2 em{color:var(--amber-dark);font-style:normal}
.plb{font-size:.92rem;color:var(--muted);line-height:1.78;margin-bottom:16px}
.sol-callout{background:var(--navy);border-radius:14px;padding:22px 24px}
.sc-tag{font-size:.68rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--amber);margin-bottom:8px}
.sol-callout p{font-size:.9rem;color:rgba(255,255,255,.75);line-height:1.65;margin:0}
.pgd{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.pgi{background:white;border:1px solid var(--border);border-radius:10px;padding:14px 16px;transition:border-color .2s,transform .2s}
.pgi:hover{border-color:var(--amber);transform:translateY(-2px)}
.pgi-ic{font-size:1.1rem;margin-bottom:6px}
.pgi-tx{font-size:.81rem;color:var(--mid);line-height:1.5}
.pgi-tx strong{color:var(--dark);font-weight:600}

/* LIFECYCLE */
.lc-sec{background:var(--navy);padding:80px 5%;position:relative;overflow:hidden}
.lc-sec::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(245,158,11,.06),transparent 60%);pointer-events:none}
.lc-inner{max-width:1100px;margin:0 auto;position:relative}
.lc-hd{text-align:center;margin-bottom:52px}
.lc-hd h2{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(1.8rem,3vw,2.4rem);font-weight:800;color:white;letter-spacing:-.8px;margin-bottom:10px}
.lc-hd p{font-size:.93rem;color:rgba(255,255,255,.5);max-width:580px;margin:0 auto}
.lc-row1{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-bottom:0;position:relative}
.lc-row1::after{content:'';position:absolute;top:27px;left:12%;right:12%;height:2px;background:linear-gradient(90deg,var(--amber),rgba(245,158,11,.2));border-radius:2px;z-index:0}
.lc-row2{display:grid;grid-template-columns:repeat(3,1fr);gap:0;max-width:660px;margin:32px auto 0;position:relative}
.lc-row2::after{content:'';position:absolute;top:27px;left:10%;right:10%;height:2px;background:linear-gradient(90deg,rgba(245,158,11,.2),var(--amber),rgba(245,158,11,.2));border-radius:2px;z-index:0}
.lc-step{display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 8px;position:relative;z-index:1}
.lcs-circle{width:54px;height:54px;border-radius:50%;background:var(--navy-light);border:2px solid rgba(245,158,11,.3);display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin-bottom:12px;transition:border-color .2s,background .2s}
.lc-step:hover .lcs-circle{border-color:var(--amber);background:rgba(245,158,11,.1)}
.lcs-name{font-family:'Bricolage Grotesque',sans-serif;font-size:.8rem;font-weight:700;color:white;line-height:1.3}
.lc-meta{text-align:center;margin-top:36px;display:flex;flex-direction:column;gap:12px;align-items:center}
.lc-meta-pills{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
.lc-pill{background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.22);border-radius:100px;padding:7px 16px;font-size:.8rem;color:var(--amber);font-weight:500}
.lc-scale{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:12px 24px;font-size:.84rem;color:rgba(255,255,255,.55)}
.lc-scale strong{color:white}

/* FEATURES */
.feat-sec{background:var(--white)}
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:1200px;margin:0 auto}
.fc{background:var(--light);border-radius:16px;border:1px solid var(--border);padding:26px 24px;transition:transform .2s,box-shadow .2s,border-color .2s;position:relative;overflow:hidden}
.fc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:16px 16px 0 0;background:linear-gradient(90deg,var(--amber),var(--amber-dark))}
.fc:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:var(--amber)}
.fc-num{font-family:'Bricolage Grotesque',sans-serif;font-size:2.5rem;font-weight:900;color:var(--border);position:absolute;top:12px;right:16px;line-height:1}
.fc-icon{width:48px;height:48px;border-radius:13px;background:var(--amber-light);display:flex;align-items:center;justify-content:center;font-size:1.3rem;margin-bottom:14px}
.fc h3{font-family:'Bricolage Grotesque',sans-serif;font-size:1rem;font-weight:800;color:var(--dark);margin-bottom:8px;line-height:1.25}
.fc p{font-size:.83rem;color:var(--muted);line-height:1.6}
.feat-extras{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;max-width:1200px;margin:20px auto 0}
.fe{background:var(--light);border:1px solid var(--border);border-radius:11px;padding:14px 16px;display:flex;align-items:center;gap:12px;transition:border-color .2s}
.fe:hover{border-color:var(--amber)}
.fe-icon{width:34px;height:34px;border-radius:8px;background:var(--amber-light);display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0}
.fe-text{font-size:.84rem;color:var(--mid)}

/* COMPARISON */
.cmp-sec{background:var(--navy);padding:80px 5%;position:relative;overflow:hidden}
.cmp-sec::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(245,158,11,.05),transparent 55%);pointer-events:none}
.cmp-inner{max-width:900px;margin:0 auto;position:relative}
.cmp-inner h2{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(1.8rem,3vw,2.4rem);font-weight:800;color:white;letter-spacing:-.8px;margin-bottom:10px}
.cmp-sub{font-size:.93rem;color:rgba(255,255,255,.5);margin-bottom:44px}
.ctable{border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,.1)}
.ct-head{display:grid;grid-template-columns:2fr 1.2fr 1.4fr;background:rgba(255,255,255,.06)}
.ct-head .ch{padding:16px 20px;font-family:'Bricolage Grotesque',sans-serif;font-size:.76rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.5)}
.ct-head .ch.hl{background:rgba(245,158,11,.12);color:var(--amber)}
.ct-row{display:grid;grid-template-columns:2fr 1.2fr 1.4fr;border-top:1px solid rgba(255,255,255,.06)}
.ct-row:nth-child(odd){background:rgba(255,255,255,.02)}
.ct-row:hover{background:rgba(255,255,255,.04)}
.ct-cell{padding:14px 20px;font-size:.85rem;display:flex;align-items:center}
.ct-cell.metric{font-weight:600;color:rgba(255,255,255,.75)}
.ct-cell.trad{color:rgba(255,255,255,.38);font-size:.82rem}
.ct-cell.good{color:#4ADE80;font-weight:700;font-size:.86rem;background:rgba(74,222,128,.04);gap:6px}
.ct-cell.good::before{content:'✓';font-size:.72rem}

/* CALCULATOR */
.calc-sec{background:var(--light);padding:80px 5%}
.calc-inner{max-width:900px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
.calc-left h2{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(1.8rem,3vw,2.3rem);font-weight:800;color:var(--dark);letter-spacing:-.8px;margin-bottom:10px}
.calc-left p{font-size:.92rem;color:var(--muted);line-height:1.75;margin-bottom:16px}
.calc-note{font-size:.76rem;color:var(--muted);font-style:italic}
.calc-card{background:var(--navy);border-radius:20px;padding:32px;box-shadow:var(--shadow-lg)}
.calc-lbl{font-size:.7rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.38);margin-bottom:10px}
.calc-iw{position:relative;margin-bottom:8px}
.calc-pfx{position:absolute;left:14px;top:50%;transform:translateY(-50%);font-family:'Bricolage Grotesque',sans-serif;font-size:1.1rem;font-weight:700;color:var(--amber)}
.calc-input{width:100%;background:rgba(255,255,255,.06);border:1.5px solid rgba(255,255,255,.12);border-radius:10px;padding:12px 12px 12px 36px;font-family:'Bricolage Grotesque',sans-serif;font-size:1.2rem;font-weight:700;color:white;outline:none;transition:border-color .2s}
.calc-input:focus{border-color:var(--amber)}
.calc-slider{width:100%;-webkit-appearance:none;height:6px;border-radius:3px;background:rgba(255,255,255,.1);outline:none;margin:12px 0 6px;cursor:pointer}
.calc-slider::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--amber);cursor:pointer;box-shadow:0 2px 8px rgba(245,158,11,.4)}
.calc-slider-lbs{display:flex;justify-content:space-between;font-size:.66rem;color:rgba(255,255,255,.28);margin-bottom:20px}
.calc-div{height:1px;background:rgba(255,255,255,.08);margin:20px 0}
.tat-row{display:flex;gap:8px;margin-bottom:20px}
.tat-btn{flex:1;padding:8px 4px;border-radius:8px;border:1.5px solid rgba(255,255,255,.12);background:transparent;color:rgba(255,255,255,.45);font-family:'Bricolage Grotesque',sans-serif;font-size:.76rem;font-weight:600;cursor:pointer;transition:all .2s;text-align:center}
.tat-btn.active{background:rgba(245,158,11,.15);border-color:var(--amber);color:var(--amber)}
.calc-res-lbl{font-size:.7rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.38);margin-bottom:8px}
.calc-res{font-family:'Bricolage Grotesque',sans-serif;font-size:2.8rem;font-weight:900;color:var(--amber);line-height:1;margin-bottom:4px;transition:all .3s}
.calc-res-sub{font-size:.76rem;color:rgba(255,255,255,.38);margin-bottom:16px}
.calc-bk{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.cb{background:rgba(255,255,255,.04);border-radius:8px;padding:10px 12px}
.cb-v{font-family:'Bricolage Grotesque',sans-serif;font-size:1rem;font-weight:700;color:white}
.cb-l{font-size:.65rem;color:rgba(255,255,255,.32);margin-top:2px}

/* BENEFITS */
.ben-sec{background:white}
.ben-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;max-width:1200px;margin:0 auto}
.ben-card{background:var(--light);border-radius:14px;border:1px solid var(--border);padding:22px 18px;transition:transform .2s,box-shadow .2s,border-color .2s}
.ben-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-color:var(--amber)}
.ben-icon{font-size:1.7rem;margin-bottom:10px}
.ben-card h4{font-family:'Bricolage Grotesque',sans-serif;font-size:.88rem;font-weight:700;color:var(--dark);margin-bottom:5px;line-height:1.3}
.ben-card p{font-size:.78rem;color:var(--muted);line-height:1.5}

/* CTA */
.cta-sec{background:var(--navy);padding:88px 5%;text-align:center;position:relative;overflow:hidden}
.cta-sec::before{content:'';position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(245,158,11,.1),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.cta-sec h2{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:800;color:white;letter-spacing:-1px;margin-bottom:14px;position:relative}
.cta-sec h2 em{color:var(--amber);font-style:normal}
.cta-sec p{font-size:.95rem;color:rgba(255,255,255,.48);margin-bottom:34px;position:relative}
.ctab{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;position:relative;margin-bottom:28px}
.bw{background:var(--amber);color:var(--navy);padding:13px 26px;border-radius:10px;font-weight:700;font-size:.92rem;font-family:'Bricolage Grotesque',sans-serif;box-shadow:0 4px 16px rgba(245,158,11,.3);transition:transform .15s,box-shadow .2s}
.bw:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(245,158,11,.35)}
.bgh{background:transparent;color:white;padding:13px 26px;border-radius:10px;font-weight:600;font-size:.92rem;border:1.5px solid rgba(255,255,255,.26);transition:background .2s;font-family:'Bricolage Grotesque',sans-serif}
.bgh:hover{background:rgba(255,255,255,.07)}
.cs{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;position:relative;margin-bottom:52px}
.cs a{color:rgba(255,255,255,.4);font-size:.82rem;display:flex;align-items:center;gap:6px;transition:color .2s}
.cs a:hover{color:white}
