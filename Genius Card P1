<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Genius Card — Contactless NFC Digital Business Card | sprintcart</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet"/>
<style>
  :root{--blue:#1A6FDB;--blue-dark:#0F4FA0;--blue-light:#E8F1FC;--green:#3DBD6A;--green-dark:#2A9A51;--green-light:#E8F8EE;--gold:#C9A227;--gold-light:#FDF8E8;--dark:#0D1B2A;--mid:#2C3E50;--muted:#637080;--light:#F4F7FB;--white:#FFFFFF;--border:#E2E8F2;--shadow:0 4px 24px rgba(26,111,219,0.10);--shadow-lg:0 16px 56px rgba(26,111,219,0.15);}
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{font-family:'DM Sans',sans-serif;color:var(--dark);background:var(--white);overflow-x:hidden;}
  h1,h2,h3,h4,h5{font-family:'Syne',sans-serif;line-height:1.15;}
  a{text-decoration:none;color:inherit;}

  /* NAV */
  nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,0.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 5%;height:68px;display:flex;align-items:center;justify-content:space-between;transition:box-shadow 0.3s;}
  nav.scrolled{box-shadow:0 2px 20px rgba(0,0,0,0.07);}
  .logo-text{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;}
  .logo-text .blue{color:var(--blue);} .logo-text .green{color:var(--green);}
  .logo-badge{font-size:0.62rem;color:var(--muted);letter-spacing:0.4px;}
  .nav-right{display:flex;align-items:center;gap:12px;}
  .nav-back{font-size:0.85rem;color:var(--muted);display:flex;align-items:center;gap:5px;padding:8px 14px;border-radius:8px;transition:background 0.2s;font-weight:500;}
  .nav-back:hover{background:var(--light);color:var(--dark);}
  .nav-cta{background:var(--blue);color:white;padding:10px 20px;border-radius:8px;font-weight:600;font-size:0.88rem;transition:background 0.2s,transform 0.15s;}
  .nav-cta:hover{background:var(--blue-dark);transform:translateY(-1px);}

  /* HERO */
  .hero{min-height:100vh;padding:110px 5% 80px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;background:linear-gradient(145deg,#F0F6FF 0%,#FAFFFE 55%,#FFFBF0 100%);position:relative;overflow:hidden;}
  .hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(26,111,219,0.035) 1px,transparent 1px),linear-gradient(90deg,rgba(26,111,219,0.035) 1px,transparent 1px);background-size:52px 52px;pointer-events:none;}
  .blob{position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none;opacity:0.28;}
  .b1{width:520px;height:520px;background:radial-gradient(circle,#1A6FDB2A,transparent 70%);top:-80px;right:42%;}
  .b2{width:320px;height:320px;background:radial-gradient(circle,#C9A22720,transparent 70%);bottom:60px;right:12%;}
  .hero-left{position:relative;animation:fadeUp 0.8s ease both;}
  .hero-right{position:relative;display:flex;justify-content:center;align-items:center;animation:fadeRight 0.9s 0.2s ease both;}
  @keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeRight{from{opacity:0;transform:translateX(28px)}to{opacity:1;transform:translateX(0)}}
  .breadcrumb{display:flex;align-items:center;gap:5px;font-size:0.78rem;color:var(--muted);margin-bottom:20px;}
  .breadcrumb .cur{color:var(--blue);font-weight:500;}
  .hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--gold-light);border:1px solid rgba(201,162,39,0.28);border-radius:100px;padding:6px 14px 6px 8px;font-size:0.78rem;font-weight:600;color:var(--gold);margin-bottom:20px;}
  .bdot{width:6px;height:6px;background:var(--gold);border-radius:50%;animation:pulse 2s infinite;}
  @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(1.4)}}
  .hero h1{font-size:clamp(2.6rem,4.5vw,3.8rem);font-weight:800;letter-spacing:-1.5px;color:var(--dark);margin-bottom:6px;}
  .hero h1 .acc{color:var(--blue);}
  .hero-tagline{font-family:'Syne',sans-serif;font-size:1rem;font-weight:600;color:var(--gold);margin-bottom:18px;}
  .hero-sub{font-size:0.98rem;color:var(--muted);line-height:1.78;max-width:520px;margin-bottom:32px;}
  .hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px;}
  .btn-primary{background:var(--blue);color:white;padding:13px 26px;border-radius:10px;font-weight:600;font-size:0.92rem;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 16px rgba(26,111,219,0.28);transition:background 0.2s,transform 0.15s,box-shadow 0.2s;}
  .btn-primary:hover{background:var(--blue-dark);transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,111,219,0.32);}
  .btn-outline{background:white;color:var(--blue);padding:13px 26px;border-radius:10px;font-weight:600;font-size:0.92rem;border:1.5px solid var(--blue);display:inline-flex;align-items:center;gap:8px;transition:background 0.2s,transform 0.15s;}
  .btn-outline:hover{background:var(--blue-light);transform:translateY(-2px);}
  .trust-row{display:flex;gap:20px;flex-wrap:wrap;padding-top:18px;border-top:1px solid var(--border);}
  .ti{display:flex;align-items:center;gap:6px;font-size:0.8rem;color:var(--muted);font-weight:500;}

  /* CARD VISUAL */
  .card-scene{position:relative;width:100%;max-width:440px;}
  .gc-card{width:290px;height:180px;background:linear-gradient(135deg,#0D1F3C 0%,#1A4A8A 50%,#1E62B5 100%);border-radius:18px;box-shadow:0 28px 64px rgba(13,31,60,0.5),0 0 0 1px rgba(255,255,255,0.07);position:relative;overflow:hidden;margin:0 auto;}
  .gc-card::before{content:'';position:absolute;top:-50px;right:-50px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,0.03);}
  .gc-card::after{content:'';position:absolute;bottom:-40px;left:-40px;width:140px;height:140px;border-radius:50%;background:rgba(61,189,106,0.07);}
  .gc-chip{position:absolute;top:22px;left:22px;width:38px;height:30px;background:linear-gradient(135deg,#C9A227,#F0D060);border-radius:5px;display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(3,1fr);gap:2px;padding:4px;}
  .gc-chip div{background:rgba(0,0,0,0.18);border-radius:1px;}
  .gc-nfc{position:absolute;top:24px;right:22px;width:22px;height:22px;opacity:0.5;}
  .gc-nfc svg{width:100%;height:100%;fill:white;}
  .gc-logo{position:absolute;bottom:22px;left:22px;width:38px;height:38px;background:linear-gradient(135deg,#C9A227,#F0D060);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;color:#0D1F3C;}
  .gc-lines{position:absolute;top:50%;left:22px;transform:translateY(-50%);}
  .gc-lines div{height:2px;background:rgba(255,255,255,0.13);border-radius:2px;margin-bottom:6px;}
  .gc-lines div:nth-child(1){width:82px;} .gc-lines div:nth-child(2){width:62px;} .gc-lines div:nth-child(3){width:72px;}
  .gc-qr{position:absolute;top:50%;right:22px;transform:translateY(-50%);width:46px;height:46px;background:rgba(255,255,255,0.12);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;}
  .gc-name{position:absolute;bottom:28px;right:22px;text-align:right;}
  .gc-name .n1{font-family:'Syne',sans-serif;font-size:0.72rem;font-weight:700;color:white;letter-spacing:0.5px;}
  .gc-name .n2{font-size:0.58rem;color:rgba(255,255,255,0.45);margin-top:2px;}
  .fc{position:absolute;background:white;border-radius:12px;border:1px solid var(--border);box-shadow:0 8px 32px rgba(0,0,0,0.10);padding:12px 16px;animation:float 4s ease-in-out infinite;}
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
  .fc-top{top:-18px;right:-12px;min-width:156px;animation-delay:0s;}
  .fc-bottom{bottom:-14px;left:-18px;min-width:172px;animation-delay:1.5s;}
  .fc-left{top:50%;left:-38px;transform:translateY(-50%);min-width:130px;animation-delay:0.8s;}
  .fc-label{font-size:0.63rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:4px;}
  .fc-row{display:flex;align-items:center;gap:8px;}
  .fc-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--green));display:flex;align-items:center;justify-content:center;color:white;font-size:0.68rem;font-weight:700;flex-shrink:0;}
  .fc-name{font-size:0.78rem;font-weight:600;color:var(--dark);}
  .fc-role{font-size:0.63rem;color:var(--muted);}
  .fc-pill{display:inline-flex;align-items:center;gap:3px;background:var(--green-light);color:var(--green-dark);font-size:0.66rem;font-weight:600;padding:3px 8px;border-radius:100px;margin-top:5px;}
  .fc-big{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;color:var(--blue);}
  .fc-sm{font-size:0.66rem;color:var(--muted);margin-top:1px;}
  .pulse-rings{position:absolute;bottom:-52px;right:44px;width:72px;height:72px;}
  .pulse-rings::before,.pulse-rings::after{content:'';position:absolute;top:50%;left:50%;width:36px;height:36px;border:2px solid var(--blue);border-radius:50%;transform:translate(-50%,-50%);animation:ripple 2s infinite;}
  .pulse-rings::after{animation-delay:1s;}
  @keyframes ripple{0%{opacity:0.6;transform:translate(-50%,-50%) scale(0.5)}100%{opacity:0;transform:translate(-50%,-50%) scale(2.8)}}

  /* SECTIONS */
  section{padding:96px 5%;}
  .mw{max-width:1200px;margin:0 auto;}
  .eyebrow{display:inline-block;font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--blue);margin-bottom:12px;}
  .sec-title{font-size:clamp(1.8rem,3vw,2.5rem);font-weight:800;color:var(--dark);letter-spacing:-0.8px;margin-bottom:14px;}
  .sec-sub{font-size:0.96rem;color:var(--muted);line-height:1.75;max-width:560px;margin-bottom:52px;}
  .center{text-align:center;}
  .center .sec-sub{margin:0 auto 52px;}

  /* PROBLEM */
  .problem-section{background:var(--dark);padding:80px 5%;position:relative;overflow:hidden;}
  .problem-section::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,111,219,0.10),transparent 55%);pointer-events:none;}
  .prob-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;position:relative;}
  .ptag{display:inline-flex;align-items:center;gap:6px;background:rgba(201,162,39,0.13);border:1px solid rgba(201,162,39,0.28);border-radius:100px;padding:5px 12px;font-size:0.74rem;color:#F0D060;font-weight:500;margin-bottom:18px;}
  .prob-left h2{font-size:clamp(1.8rem,3vw,2.5rem);font-weight:800;color:white;letter-spacing:-0.8px;margin-bottom:14px;}
  .prob-left h2 span{color:var(--green);}
  .prob-left p{font-size:0.92rem;color:rgba(255,255,255,0.58);line-height:1.78;margin-bottom:26px;}
  .sol-callout{background:rgba(61,189,106,0.08);border:1px solid rgba(61,189,106,0.2);border-radius:14px;padding:22px 24px;}
  .sol-tag{font-size:0.7rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--green);margin-bottom:8px;}
  .sol-callout p{font-size:0.89rem;color:rgba(255,255,255,0.7);line-height:1.65;font-style:italic;margin:0;}
  .prob-cards{display:flex;flex-direction:column;gap:14px;}
  .prob-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:18px 20px;display:flex;align-items:flex-start;gap:14px;transition:border-color 0.2s;}
  .prob-card:hover{border-color:rgba(255,255,255,0.15);}
  .prob-icon{width:38px;height:38px;border-radius:9px;background:rgba(255,100,100,0.12);border:1px solid rgba(255,100,100,0.18);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
  .pt{font-size:0.87rem;font-weight:600;color:white;margin-bottom:3px;}
  .pd{font-size:0.77rem;color:rgba(255,255,255,0.48);line-height:1.5;}

  /* HOW IT WORKS */
  .hiw{background:var(--light);}
  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1100px;margin:0 auto;}
  .step{background:white;border-radius:20px;border:1px solid var(--border);padding:32px 28px;position:relative;overflow:hidden;transition:transform 0.25s,box-shadow 0.25s;}
  .step:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg);}
  .step-num{font-family:'Syne',sans-serif;font-size:3.5rem;font-weight:800;color:var(--border);position:absolute;top:14px;right:18px;line-height:1;}
  .step-icon{width:54px;height:54px;border-radius:15px;background:var(--blue-light);display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:18px;}
  .step h3{font-size:1.08rem;font-weight:700;color:var(--dark);margin-bottom:8px;}
  .step p{font-size:0.86rem;color:var(--muted);line-height:1.65;}

  /* FEATURES */
  .feat-section{background:white;}
  .ftabs{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:48px;}
  .ftab{padding:9px 18px;border-radius:100px;font-size:0.83rem;font-weight:600;cursor:pointer;border:1.5px solid var(--border);color:var(--muted);transition:all 0.2s;}
  .ftab.active,.ftab:hover{background:var(--blue);color:white;border-color:var(--blue);}
  .fpanel{display:none;grid-template-columns:1fr 1fr;gap:60px;align-items:start;max-width:1100px;margin:0 auto;}
  .fpanel.active{display:grid;}
  .fp-tag{font-size:0.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--blue);margin-bottom:10px;}
  .fp-h{font-size:clamp(1.6rem,2.5vw,2.1rem);font-weight:800;color:var(--dark);letter-spacing:-0.5px;margin-bottom:12px;}
  .fp-p{font-size:0.92rem;color:var(--muted);line-height:1.75;margin-bottom:22px;}
  .flist{display:flex;flex-direction:column;gap:10px;margin-bottom:28px;}
  .fi{display:flex;align-items:flex-start;gap:10px;font-size:0.87rem;color:var(--mid);}
  .fi::before{content:'✓';color:var(--blue);font-weight:700;flex-shrink:0;margin-top:1px;}
  .fvisual{background:var(--light);border-radius:20px;border:1px solid var(--border);padding:24px;display:flex;flex-direction:column;gap:14px;}
  .fv-card{background:white;border-radius:12px;border:1px solid var(--border);padding:16px;box-shadow:0 2px 12px rgba(0,0,0,0.05);}
  .fv-head{display:flex;align-items:center;gap:10px;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--border);}
  .fv-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--green));display:flex;align-items:center;justify-content:center;color:white;font-size:0.72rem;font-weight:700;flex-shrink:0;}
  .fv-n{font-size:0.82rem;font-weight:600;color:var(--dark);}
  .fv-r{font-size:0.68rem;color:var(--muted);}
  .fv-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:0.78rem;}
  .fv-row:last-child{border-bottom:none;}
  .rk{color:var(--muted);}
  .rv{font-weight:600;color:var(--dark);}
  .rv.g{color:var(--green-dark);}
  .fv-pill{display:inline-flex;align-items:center;gap:3px;background:var(--green-light);color:var(--green-dark);font-size:0.66rem;font-weight:600;padding:3px 8px;border-radius:100px;}
  .fv-mini{background:linear-gradient(135deg,#0D1F3C,#1A6FDB);border-radius:10px;padding:14px 16px;color:white;display:flex;align-items:center;gap:12px;}
  .fv-mi{width:38px;height:38px;border-radius:9px;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
  .fv-mt{font-size:0.84rem;font-weight:600;}
  .fv-ms{font-size:0.7rem;color:rgba(255,255,255,0.55);}
  .icon-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  .ig-item{background:var(--light);border-radius:10px;padding:12px;}
  .ig-icon{font-size:1.2rem;margin-bottom:5px;}
  .ig-label{font-size:0.75rem;font-weight:600;color:var(--dark);margin-bottom:3px;}
  .ig-desc{font-size:0.68rem;color:var(--muted);line-height:1.4;}

  /* UNIQUE CAPABILITIES */
  .caps{background:var(--light);}
  .caps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1200px;margin:0 auto;}
  .cap-card{background:white;border-radius:20px;border:1px solid var(--border);padding:32px;transition:transform 0.2s,box-shadow 0.2s,border-color 0.2s;}
  .cap-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:var(--blue);}
  .cap-badge{display:inline-block;font-size:0.63rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:3px 8px;border-radius:100px;margin-bottom:12px;}
  .cb-ent{background:var(--blue-light);color:var(--blue);}
  .cb-new{background:var(--green-light);color:var(--green-dark);}
  .cb-opt{background:var(--gold-light);color:var(--gold);}
  .cap-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:16px;}
  .ci-blue{background:var(--blue-light);}
  .ci-green{background:var(--green-light);}
  .ci-gold{background:var(--gold-light);}
  .cap-card h3{font-size:1.05rem;font-weight:700;color:var(--dark);margin-bottom:8px;}
  .cap-card p{font-size:0.85rem;color:var(--muted);line-height:1.65;margin-bottom:16px;}
  .cap-list{display:flex;flex-direction:column;gap:7px;}
  .cap-li{font-size:0.81rem;color:var(--mid);display:flex;align-items:flex-start;gap:7px;line-height:1.45;}
  .cap-li::before{content:'→';color:var(--blue);font-weight:700;flex-shrink:0;font-size:0.78rem;margin-top:1px;}

  /* USE CASES */
  .uc-sec{background:white;}
  .uc-tabs{display:flex;gap:0;border:1.5px solid var(--border);border-radius:12px;overflow:hidden;max-width:520px;margin:0 auto 48px;}
  .uctab{flex:1;padding:12px 14px;font-size:0.84rem;font-weight:600;cursor:pointer;color:var(--muted);transition:all 0.2s;text-align:center;border-right:1.5px solid var(--border);}
  .uctab:last-child{border-right:none;}
  .uctab.active{background:var(--blue);color:white;}
  .ucpanel{display:none;max-width:1100px;margin:0 auto;}
  .ucpanel.active{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;}
  .ucc h3{font-size:1.45rem;font-weight:800;color:var(--dark);margin-bottom:10px;}
  .ucc p{font-size:0.91rem;color:var(--muted);line-height:1.75;margin-bottom:22px;}
  .uc-list{display:flex;flex-direction:column;gap:10px;}
  .uc-li{display:flex;align-items:flex-start;gap:9px;font-size:0.86rem;color:var(--mid);}
  .uc-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);flex-shrink:0;margin-top:6px;}
  .ucv{background:var(--light);border-radius:18px;padding:24px;border:1px solid var(--border);}
  .ucv-item{background:white;border-radius:10px;padding:13px 14px;border:1px solid var(--border);margin-bottom:10px;display:flex;align-items:center;gap:12px;}
  .ucv-item:last-child{margin-bottom:0;}
  .ucv-icon{width:36px;height:36px;border-radius:9px;background:var(--blue-light);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
  .ucv-title{font-size:0.82rem;font-weight:600;color:var(--dark);}
  .ucv-sub{font-size:0.7rem;color:var(--muted);}

  /* BENEFITS */
  .ben-sec{background:var(--light);}
  .ben-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;max-width:1200px;margin:0 auto;}
  .ben-card{background:white;border-radius:16px;border:1px solid var(--border);padding:28px 22px;transition:transform 0.2s,box-shadow 0.2s;}
  .ben-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);}
  .ben-icon{font-size:1.8rem;margin-bottom:14px;}
  .ben-card h4{font-size:0.92rem;font-weight:700;color:var(--dark);margin-bottom:6px;line-height:1.3;}
  .ben-card p{font-size:0.8rem;color:var(--muted);line-height:1.55;}

  /* CTA */
  .cta-sec{background:var(--dark);padding:96px 5%;text-align:center;position:relative;overflow:hidden;}
