<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Jubilee — Brand Merchandise Store | sprintcart</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet"/>
<style>
:root{
  --rose:#E91E8C;--rose-dark:#C01570;--rose-mid:#F06AAD;--rose-light:#FDE8F4;
  --coral:#FF6B6B;--coral-light:#FFF0F0;
  --gold:#F59E0B;--gold-light:#FEF3C7;
  --purple:#7C3AED;--purple-light:#F3E8FF;
  --sc-blue:#1A6FDB;--sc-green:#3DBD6A;
  --dark:#1A0A14;--mid:#3D1A2E;--muted:#8B5A7A;
  --light:#FDF5F9;--white:#FFFFFF;--border:#F0D6E8;
  --shadow:0 4px 24px rgba(233,30,140,.08);
  --shadow-lg:0 20px 60px rgba(233,30,140,.14);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;color:var(--dark);background:var(--white);overflow-x:hidden}
h1,h2,h3,h4{font-family:'Playfair Display',sans-serif;line-height:1.15}
a{text-decoration:none;color:inherit}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,.96);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);padding:0 5%;height:68px;display:flex;align-items:center;justify-content:space-between;transition:box-shadow .3s}
nav.scrolled{box-shadow:0 2px 24px rgba(0,0,0,.07)}
.lt{font-family:'DM Sans',sans-serif;font-size:1.45rem;font-weight:700;letter-spacing:-.5px}
.lt .b{color:var(--sc-blue)}.lt .g{color:var(--sc-green)}
.lb{font-size:.6rem;color:var(--muted);letter-spacing:.5px}
.nr{display:flex;align-items:center;gap:12px}
.nbk{font-size:.84rem;color:var(--muted);padding:8px 14px;border-radius:8px;transition:background .2s;font-weight:500}
.nbk:hover{background:var(--rose-light);color:var(--rose-dark)}
.nct{background:var(--rose);color:white;padding:10px 20px;border-radius:8px;font-weight:600;font-size:.88rem;transition:background .2s,transform .15s}
.nct:hover{background:var(--rose-dark);transform:translateY(-1px)}

/* HERO */
.hero{min-height:100vh;padding:110px 5% 80px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;position:relative;overflow:hidden;background:linear-gradient(145deg,#FFF5FB 0%,#FFFBF5 55%,#FFF5F5 100%)}
.hero::before{content:'';position:absolute;top:-100px;right:-80px;width:700px;height:700px;background:radial-gradient(ellipse,rgba(233,30,140,.07) 0%,transparent 65%);border-radius:50%;pointer-events:none}
.hero::after{content:'';position:absolute;bottom:-60px;left:0;width:400px;height:400px;background:radial-gradient(ellipse,rgba(255,107,107,.05) 0%,transparent 65%);border-radius:50%;pointer-events:none}
.hgrid{position:absolute;inset:0;background-image:radial-gradient(rgba(233,30,140,.06) 1px,transparent 1px);background-size:36px 36px;pointer-events:none}
.hl{position:relative;z-index:1;animation:fu .8s ease both}
.hr{position:relative;z-index:1;animation:fir .9s .2s ease both}
@keyframes fu{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes fir{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
.bc{display:flex;align-items:center;gap:5px;font-size:.77rem;color:var(--muted);margin-bottom:20px;font-family:'DM Sans',sans-serif}
.bc .cur{color:var(--rose);font-weight:600}
.hbg{display:inline-flex;align-items:center;gap:8px;background:var(--rose-light);border:1px solid rgba(233,30,140,.22);border-radius:100px;padding:6px 14px 6px 8px;font-size:.77rem;font-weight:600;color:var(--rose-dark);margin-bottom:22px}
.bdot{width:6px;height:6px;background:var(--rose);border-radius:50%;animation:bp 2s infinite}
@keyframes bp{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
.hero h1{font-size:clamp(2.6rem,4.5vw,4rem);font-weight:800;letter-spacing:-1.5px;color:var(--dark);line-height:1.05;margin-bottom:6px}
.hero h1 .ac{color:var(--rose)}
.htag{font-family:'Playfair Display',sans-serif;font-size:1.1rem;font-weight:600;font-style:italic;color:var(--rose-mid);margin-bottom:18px}
.hero-sub{font-size:1rem;color:var(--muted);line-height:1.78;max-width:520px;margin-bottom:32px}
.ha{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px}
.bpr{background:var(--rose);color:white;padding:13px 26px;border-radius:10px;font-weight:600;font-size:.92rem;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 16px rgba(233,30,140,.28);transition:background .2s,transform .15s,box-shadow .2s}
.bpr:hover{background:var(--rose-dark);transform:translateY(-2px);box-shadow:0 8px 24px rgba(233,30,140,.32)}
.bor{background:white;color:var(--rose);padding:13px 26px;border-radius:10px;font-weight:600;font-size:.92rem;border:1.5px solid var(--rose);display:inline-flex;align-items:center;gap:8px;transition:background .2s,transform .15s}
.bor:hover{background:var(--rose-light);transform:translateY(-2px)}
.tr{display:flex;gap:20px;flex-wrap:wrap;padding-top:18px;border-top:1px solid var(--border)}
.ti{display:flex;align-items:center;gap:6px;font-size:.79rem;color:var(--muted);font-weight:500}

/* HERO VISUAL */
.hvc{position:relative;width:100%;max-width:460px;margin:0 auto}
.hvm{background:white;border-radius:24px;border:1px solid var(--border);box-shadow:var(--shadow-lg);padding:24px}
.hvm-top{background:linear-gradient(135deg,var(--rose),var(--coral));border-radius:14px;padding:20px;margin-bottom:16px;text-align:center}
.hvmt{font-family:'Playfair Display',sans-serif;font-size:1.4rem;font-weight:700;color:white;font-style:italic}
.hvms{font-size:.8rem;color:rgba(255,255,255,.75);margin-top:4px}
.hvm-cats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px}
.hvc-item{background:var(--light);border:1px solid var(--border);border-radius:10px;padding:10px 8px;text-align:center;transition:border-color .2s}
.hvc-item:hover{border-color:var(--rose)}
.hvc-icon{font-size:1.3rem;margin-bottom:4px}
.hvc-name{font-size:.67rem;font-weight:600;color:var(--mid)}
.hvm-divider{height:1px;background:var(--border);margin:12px 0}
.hvm-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;font-size:.77rem}
.hvm-row .rk{color:var(--muted)}.hvm-row .rv{font-weight:600;color:var(--dark)}.hvm-row .rv.p{color:var(--rose)}
.hvm-pill{display:inline-flex;align-items:center;gap:3px;background:var(--rose-light);color:var(--rose-dark);font-size:.65rem;font-weight:700;padding:3px 8px;border-radius:100px}
.hfc{position:absolute;background:white;border-radius:12px;border:1px solid var(--border);box-shadow:0 8px 32px rgba(233,30,140,.1);padding:12px 15px;animation:fl 4s ease-in-out infinite;z-index:3}
@keyframes fl{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.hfc-tl{top:-16px;left:-16px;min-width:142px;animation-delay:.5s}
.hfc-br{bottom:-14px;right:-14px;min-width:152px;animation-delay:1.8s}
.hfcl{font-size:.62rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.hfcv{font-family:'Playfair Display',sans-serif;font-size:1.3rem;font-weight:700;color:var(--rose)}
.hfcs{font-size:.64rem;color:var(--muted);margin-top:2px}

/* SECTIONS */
section{padding:88px 5%}
.mw{max-width:1200px;margin:0 auto}
.ew{display:inline-block;font-size:.71rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--rose);margin-bottom:12px;font-family:'DM Sans',sans-serif}
.st{font-size:clamp(1.9rem,3vw,2.6rem);font-weight:700;color:var(--dark);letter-spacing:-.5px;margin-bottom:14px}
.ss{font-size:.95rem;color:var(--muted);line-height:1.75;max-width:560px;margin-bottom:48px}
.cnt{text-align:center}.cnt .ss{margin:0 auto 48px}

/* WHY IT MATTERS */
.why-sec{background:var(--dark);padding:80px 5%;position:relative;overflow:hidden}
.why-sec::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(233,30,140,.12),transparent 55%);pointer-events:none}
.why-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;position:relative}
.wl-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(233,30,140,.14);border:1px solid rgba(233,30,140,.28);border-radius:100px;padding:5px 12px;font-size:.73rem;color:var(--rose-mid);font-weight:600;margin-bottom:18px;font-family:'DM Sans',sans-serif}
.why-inner h2{font-size:clamp(1.8rem,3vw,2.5rem);font-weight:700;color:white;letter-spacing:-.5px;margin-bottom:16px}
.why-inner h2 em{color:var(--rose-mid);font-style:normal}
.wl-body{font-size:.92rem;color:rgba(255,255,255,.55);line-height:1.78;margin-bottom:20px}
.stat-callout{background:rgba(233,30,140,.1);border:1px solid rgba(233,30,140,.25);border-radius:14px;padding:22px 24px;margin-bottom:20px}
.sc-num{font-family:'Playfair Display',sans-serif;font-size:3rem;font-weight:700;color:var(--rose-mid);line-height:1;margin-bottom:6px}
.sc-label{font-size:.87rem;color:rgba(255,255,255,.7);line-height:1.55}
.sol-callout{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:20px 22px}
.sc-tag-sm{font-size:.68rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--rose-mid);margin-bottom:7px;font-family:'DM Sans',sans-serif}
.sol-callout p{font-size:.88rem;color:rgba(255,255,255,.65);line-height:1.65;margin:0}
.why-right{display:flex;flex-direction:column;gap:14px}
.wr-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:18px 20px;transition:border-color .2s,background .2s}
.wr-card:hover{background:rgba(255,255,255,.07);border-color:rgba(233,30,140,.25)}
.wrc-icon{font-size:1.2rem;margin-bottom:8px}
.wrc-title{font-size:.9rem;font-weight:600;color:white;margin-bottom:5px}
.wrc-body{font-size:.81rem;color:rgba(255,255,255,.48);line-height:1.55}

/* WHAT JUBILEE DELIVERS */
.delivers-sec{background:var(--light)}
.del-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1200px;margin:0 auto}
.del-card{background:white;border-radius:20px;border:1px solid var(--border);padding:32px;transition:transform .22s,box-shadow .22s,border-color .22s;position:relative;overflow:hidden}
.del-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:20px 20px 0 0}
.del-card.d1c::before{background:linear-gradient(90deg,var(--rose),var(--rose-mid))}
.del-card.d2c::before{background:linear-gradient(90deg,var(--coral),#FF8E8E)}
.del-card.d3c::before{background:linear-gradient(90deg,var(--gold),#FCD34D)}
.del-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg);border-color:var(--rose)}
.del-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:16px}
.del-icon.r{background:var(--rose-light)}
.del-icon.c{background:var(--coral-light)}
.del-icon.g{background:var(--gold-light)}
.del-card h3{font-size:1.1rem;font-weight:700;color:var(--dark);margin-bottom:12px}
.del-list{display:flex;flex-direction:column;gap:8px}
.dl-item{display:flex;align-items:flex-start;gap:8px;font-size:.84rem;color:var(--mid);line-height:1.5}
.dl-item::before{content:'✓';color:var(--rose);font-weight:700;flex-shrink:0;margin-top:1px;font-size:.78rem}

/* ROC AUTOMATION */
.roc-sec{background:white}
.roc-inner{max-width:1100px;margin:0 auto}
.roc-intro{max-width:700px;margin:0 auto 52px;text-align:center}
.roc-intro p{font-size:.95rem;color:var(--muted);line-height:1.75}
.roc-intro strong{color:var(--dark)}
.roc-occasions{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:20px;margin-bottom:48px}
.roc-occ{background:var(--rose-light);border:1px solid rgba(233,30,140,.18);border-radius:100px;padding:7px 16px;font-size:.82rem;color:var(--rose-dark);font-weight:500}
.roc-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:48px;position:relative}
.roc-steps::before{content:'';position:absolute;top:32px;left:15%;right:15%;height:2px;background:linear-gradient(90deg,var(--rose),var(--rose-mid),var(--rose));z-index:0;border-radius:2px}
.roc-step{background:var(--light);border-radius:16px;border:1px solid var(--border);padding:28px 24px;text-align:center;position:relative;z-index:1;transition:transform .2s,box-shadow .2s}
.roc-step:hover{transform:translateY(-4px);box-shadow:var(--shadow)}
.rs-num{width:56px;height:56px;border-radius:50%;background:white;border:2px solid var(--rose);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',sans-serif;font-size:1.3rem;font-weight:700;color:var(--rose);margin:0 auto 14px}
.roc-step h3{font-size:1rem;font-weight:700;color:var(--dark);margin-bottom:8px}
.roc-step p{font-size:.83rem;color:var(--muted);line-height:1.6}
.roc-auto-box{background:var(--dark);border-radius:16px;padding:32px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
.roc-auto-title{grid-column:1/-1;font-size:.72rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--rose-mid);margin-bottom:4px;font-family:'DM Sans',sans-serif}
.roc-auto-headline{grid-column:1/-1;font-size:1.05rem;font-weight:600;color:white;margin-bottom:4px}
.roc-auto-sub{grid-column:1/-1;font-size:.83rem;color:rgba(255,255,255,.45);font-style:italic;margin-bottom:8px}
.rab{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:16px;transition:border-color .2s}
.rab:hover{border-color:rgba(233,30,140,.3)}
.rab-icon{font-size:1.3rem;margin-bottom:8px}
.rab-text{font-size:.83rem;color:rgba(255,255,255,.65);line-height:1.5}

/* REWARDS */
.rewards-sec{background:var(--light)}
.rew-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;max-width:1100px;margin:0 auto 48px}
.rew-card{background:white;border-radius:16px;border:1px solid var(--border);padding:28px 24px;text-align:center;transition:transform .2s,box-shadow .2s,border-color .2s}
.rew-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:var(--rose)}
.rew-icon{font-size:2rem;margin-bottom:12px}
.rew-card h3{font-size:1rem;font-weight:700;color:var(--dark);margin-bottom:6px}
.rew-card p{font-size:.82rem;color:var(--muted);line-height:1.55}
.payout-callout{background:var(--dark);border-radius:14px;padding:22px 28px;max-width:700px;margin:0 auto;text-align:center}
.pc-label{font-size:.7rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--rose-mid);margin-bottom:8px;font-family:'DM Sans',sans-serif}
.payout-callout p{font-size:.9rem;color:rgba(255,255,255,.65);line-height:1.65;margin:0}

/* BENEFITS */
.ben-sec{background:white}
.ben-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;max-width:1100px;margin:0 auto}
.ben-card{background:var(--light);border-radius:14px;border:1px solid var(--border);padding:22px 20px;transition:transform .2s,box-shadow .2s,border-color .2s}
.ben-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-color:var(--rose)}
.ben-icon{font-size:1.6rem;margin-bottom:10px}
.ben-card h4{font-size:.9rem;font-weight:700;color:var(--dark);margin-bottom:5px;line-height:1.3}
.ben-card p{font-size:.78rem;color:var(--muted);line-height:1.5}

/* CTA */
.cta-sec{background:linear-gradient(135deg,var(--rose-dark) 0%,var(--rose) 50%,var(--coral) 100%);padding:88px 5%;text-align:center;position:relative;overflow:hidden}
.cta-sec::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");pointer-events:none}
.cta-sec h2{font-size:clamp(2rem,3.5vw,3rem);font-weight:700;color:white;letter-spacing:-.5px;margin-bottom:14px;position:relative}
.cta-sec h2 em{font-style:italic;color:rgba(255,255,255,.85)}
.cta-sec p{font-size:.95rem;color:rgba(255,255,255,.75);margin-bottom:34px;position:relative}
.ctab{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;position:relative;margin-bottom:28px}
.bw{background:white;color:var(--rose-dark);padding:13px 26px;border-radius:10px;font-weight:700;font-size:.92rem;box-shadow:0 4px 16px rgba(0,0,0,.15);transition:transform .15s,box-shadow .2s}
.bw:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.2)}
.bgh{background:transparent;color:white;padding:13px 26px;border-radius:10px;font-weight:600;font-size:.92rem;border:1.5px solid rgba(255,255,255,.5);transition:background .2s}
.bgh:hover{background:rgba(255,255,255,.1)}
.cs{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;position:relative;margin-bottom:52px}
.cs a{color:rgba(255,255,255,.7);font-size:.82rem;display:flex;align-items:center;gap:6px;transition:color .2s}
.cs a:hover{color:white}
.op{padding-top:44px;border-top:1px solid rgba(255,255,255,.2);position:relative}
.opl{font-size:.68rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.6);margin-bottom:18px;font-family:'DM Sans',sans-serif}
.opr{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.opi{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);border-radius:11px;padding:13px 18px;display:flex;align-items:center;gap:10px;transition:background .2s}
.opi:hover{background:rgba(255,255,255,.2)}
.opn{font-size:.82rem;font-weight:700;color:white}
.ops{font-size:.66rem;color:rgba(255,255,255,.6)}

/* FOOTER */
footer{background:#0A0610;padding:38px 5% 22px;border-top:1px solid rgba(255,255,255,.06)}
.ftr{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;margin-bottom:20px}
.ftl{font-family:'DM Sans',sans-serif;font-size:1.3rem;font-weight:700}
.ftl .b{color:var(--sc-blue)}.ftl .g{color:var(--sc-green)}
.ftt{font-size:.75rem;color:rgba(255,255,255,.28);margin-top:3px}
.ftlk{display:flex;gap:20px;flex-wrap:wrap}
.ftlk a{font-size:.8rem;color:rgba(255,255,255,.34);transition:color .2s}
.ftlk a:hover{color:white}
.ftb{padding-top:16px;border-top:1px solid rgba(255,255,255,.06);display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
.ftb p{font-size:.72rem;color:rgba(255,255,255,.16)}
.isp{display:flex;align-items:center;gap:5px;font-size:.66rem;color:rgba(255,255,255,.28)}
.isd{width:5px;height:5px;background:var(--rose);border-radius:50%}

/* REVEAL */
.reveal{opacity:0;transform:translateY(22px);transition:opacity .6s,transform .6s}
.reveal.visible{opacity:1;transform:translateY(0)}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

@media(max-width:1024px){
  .hero,.why-inner{grid-template-columns:1fr}
  .hr{display:none}
  .del-grid,.rew-grid{grid-template-columns:1fr 1fr}
  .roc-steps{grid-template-columns:1fr}
  .roc-steps::before{display:none}
  .roc-auto-box{grid-template-columns:1fr}
  .ben-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:640px){
  .del-grid,.rew-grid,.ben-grid,.pgd{grid-template-columns:1fr}
}
</style>
</head>
<body>

<nav id="nav">
  <div><div class="lt"><span class="b">sprint</span><span class="g">cart</span>™</div><div class="lb">Enterprise Customer Engagement Platform</div></div>
  <div class="nr"><a href="#" class="nbk">← All Solutions</a><a href="#" class="nct">📅 Book a Demo</a></div>
</nav>

